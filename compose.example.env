# === User settings: edit before first run ===
# Proxy used by browser-reg during account registration.
REGISTER_PROXY_URL=socks5://host.docker.internal:10813
# Proxy used only while building the shared Camoufox base image.
CAMOUFOX_FETCH_PROXY=http://host.docker.internal:10809
# Creates a checkout session after registration, but does not confirm payment.
# Eligibility is based on Stripe init due/amount_due; checkout_url alone is not trusted.
BROWSER_CHECK_PLUS_TRIAL=false

# Optional OutlookRegister mailbox pool settings. Registration runs inside
# outlook-register-service; outlook-imap-service only manages the mailbox pool and Graph polling.
OUTLOOK_REGISTER_ENABLED=false
OUTLOOK_REGISTER_PROXY=
# Optional proxy pool for Outlook registration/OAuth. If set, it overrides
# OUTLOOK_REGISTER_PROXY and rotates one proxy per registration/OAuth attempt.
# Use comma/space/newline separators, or point OUTLOOK_REGISTER_PROXY_FILE to
# a file inside the container, for example /app/Results/proxies.txt.
OUTLOOK_REGISTER_PROXY_POOL=
OUTLOOK_REGISTER_PROXY_FILE=
OUTLOOK_REGISTER_BROWSER=patchright
OUTLOOK_REGISTER_EMAIL_SUFFIX=@outlook.com
OUTLOOK_REGISTER_ENABLE_OAUTH2=true
# Optional. Leave blank to use the built-in public client config.
OUTLOOK_REGISTER_OAUTH_CLIENT_ID=
OUTLOOK_REGISTER_OAUTH_REDIRECT_URL=
OUTLOOK_REGISTER_OAUTH_SCOPES=offline_access https://graph.microsoft.com/Mail.Read
OUTLOOK_REGISTER_MAX_TASKS=1
OUTLOOK_REGISTER_CONCURRENT_FLOWS=1
OUTLOOK_REGISTER_MANUAL_CAPTCHA=false
OUTLOOK_REGISTER_MANUAL_CAPTCHA_TIMEOUT_SECONDS=300
OUTLOOK_REGISTER_RUN_TIMEOUT_SECONDS=900
OUTLOOK_REGISTER_LOCK_WAIT_SECONDS=0
MAILBOX_REGISTER_TIMEOUT_SECONDS=1800

# GoPay account and proxy used by gopay-payment.
GOPAY_COUNTRY_CODE=62
GOPAY_PHONE_NUMBER=
GOPAY_PIN=
GOPAY_PROXY_URL=socks5://host.docker.internal:10813


# === Optional host ports: change only when local ports conflict ===
DASHBOARD_PORT=8080
GOPAY_WEBHOOK_PORT=8081
POSTGRES_PORT=5432
TEMPORAL_PORT=7233
BROWSER_REG_GRPC_PORT=50050
ACCOUNT_DB_GRPC_PORT=50052
OUTLOOK_GRPC_PORT=50053
OUTLOOK_REGISTER_GRPC_PORT=50056
GOPAY_GRPC_PORT=50054
ORCHESTRATOR_GRPC_PORT=50055


# === Stable defaults: normally do not edit ===
# Optional Outlook OAuth/Graph tuning. Leave blank/default unless using your own Azure app.
OUTLOOK_OAUTH_CLIENT_ID=
OUTLOOK_OAUTH_SCOPE=https://graph.microsoft.com/Mail.Read
OUTLOOK_GRAPH_MESSAGES_URL=
OUTLOOK_POLL_INTERVAL_SECONDS=5
OUTLOOK_MESSAGE_LIMIT=25
OUTLOOK_HTTP_TIMEOUT_SECONDS=20
OUTLOOK_ALIAS_RANDOM_LENGTH=6

# Core database.
POSTGRES_USER=nb_register
POSTGRES_PASSWORD=nb_register
POSTGRES_DB=nb_register

# Temporal persistence databases and worker routing.
TEMPORAL_DB=temporal
TEMPORAL_VISIBILITY_DB=temporal_visibility
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=nb-register-orchestrator

# Internal service addresses used by orchestrator.
PAYMENT_ADDR=gopay-payment:50051
OTP_ADDR=gopay-payment:50051
MAILBOX_REGISTER_ADDR=outlook-register-service:50051

# GoPay service-side OTP wait config.
GOPAY_OTP_SERVICE_ADDR=gopay-payment:50051
GOPAY_OTP_TIMEOUT_SECONDS=60
REGISTRATION_OTP_TIMEOUT_SECONDS=180
